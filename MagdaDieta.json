  "dishes": {
    "1": {
      "id": 1,
      "name": "Jaja na miękko z warzywami w paseczkach",
      "recipe": "Jaja ugotuj na miękko, warzywa pokrój w cienkie słupki dopraw, posyp natką i dodaj oliwę."
    },
    "2": {
      "id": 2,
      "name": "Tortilla z awokado i camembertem",
      "recipe": "Na tortilli rozsmaruj awokado, dodaj plasterki sera i warzywa, zawiń."
    },
    "3": {
      "id": 3,
      "name": "Jednogarnkowe danie z ziemniakami, cukinią i indykiem",
      "recipe": "Cukinię i ziemniaki obierz i pokrój w talarki. W garnku lub głębokiej patelni rozgrzewamy olej. Dodaj mięso mielone i podsmaż do zarumienienia (ok. 5 minut). Następnie dodaj pokrojone warzywa i smaż całość przez kolejne 5 minut, dokładnie wymieszaj. Dopraw solą, pieprzem, oregano, papryką. Zalej całość do powierzchni warzyw woda/bulionem. Doprowadź do wrzenia i zmniejsz ogień. Danie gotuj na wolnym ogniu, pod częściowym przykryciem przez 20-25 minut. Na koniec posyp posiekaną natką pietruszki lub bazylią."
    },
    "4": {
      "id": 4,
      "name": "Baton dobra kaloria",
      "recipe": ""
    },
    "5": {
      "id": 5,
      "name": "Sałatka z fetą i pomidorkami",
      "recipe": "Pomidorki pokrój, wymieszaj z pokruszoną fetą i natką pietruszki. Dopraw, skrop sokiem z cytryny, oliwą i wymieszaj. Podaj z pieczywem."
    },
    "6": {
      "id": 6,
      "name": "Omlet z warzywami",
      "recipe": "Cebulę posiekaj, paprykę pokrój w drobną kostkę. Podsmaż na patelni na rozgrzanej oliwie. Na koniec smażenia dodaj pokrojonego w kostkę pomidora. W miseczce roztrzep widelcem jajka, dopraw. Wlej na patelnię i smaż na małym ogniu pod przykryciem, aż do ścięcia. Posyp natką i przewróć omlet na drugą stronę. Gotowy posyp kiełkami/natką i pokruszoną fetą."
    },
    "7": {
      "id": 7,
      "name": "Owsianka z migdałowym jogurtem i nasionami",
      "recipe": "Płatki zalać wrzątkiem i odstawić do nasiąknięcia. Dodać chia, płatki migdałów, jogurt, kakao, owoce."
    },
    "8": {
      "id": 8,
      "name": "Spaghetti z pulpecikami i makaronem ryżowym",
      "recipe": "Makaron ugotuj al dente. Posiekaj drobno natkę pietruszki i czosnek. Przełóż do dużej miski, dodaj mięso. Przypraw solą i pieprzem. Całość wymieszaj rękami. Z masy mięsnej formuj małe kuleczki. Ugotuj do miękkości w bulionie. Na patelni rozgrzej oliwę, wlej pomidory, dopraw ziołami i po ok. 10 min. dodaj odsączone pulpety oraz makaron. Podgrzej kilka chwil. Podawaj posypane natką pietruszki."
    },
    "9": {
      "id": 9,
      "name": "Skyr z bananem i kiwi",
      "recipe": "Do jogurtu dodać owoce, opcjonalnie cynamon/kakao."
    },
    "10": {
      "id": 10,
      "name": "Kanapka caprese",
      "recipe": "Kromki posmaruj masłem. Pokrój mozzarellę i pomidora w plasterki. Ułóż ser i pomidora na przemian na kanapkach. Możesz włożyć kanapkę do airfryera na około 5 minut. Kanapkę posyp przyprawami, dodaj ogórek."
    },
    "11": {
      "id": 11,
      "name": "Sałatka z camembertem",
      "recipe": "Z octu balsamicznego, oliwy i miodu przygotować sos. Na talerz wyłożyć liście szpinaku, kawałki szynki, kawałki gruszki. Dodać pokrojony w kostkę ser, połówki pomidorków. Sałatkę polać wcześniej przygotowanym sosem, podać z pieczywem/grzanką."
    },
    "12": {
      "id": 12,
      "name": "Papryka czerwona słodka",
      "recipe": ""
    },
    "13": {
      "id": 13,
      "name": "Ser camembert",
      "recipe": ""
    },
    "14": {
      "id": 14,
      "name": "Roszponka",
      "recipe": ""
    },
    "15": {
      "id": 15,
      "name": "Bułka żytnia",
      "recipe": ""
    },
    "16": {
      "id": 16,
      "name": "Ogórek",
      "recipe": ""
    },
    "17": {
      "id": 17,
      "name": "Zupa kalafiorowa",
      "recipe": "Podsmażyć krótko por i pokrojone obrane warzywa na oliwie, zalać wodą lub bulionem (ok. 2 szklanki). Ugotować włoszczyznę wraz z piersią indyka. Dodać ziele angielskie, pieprz ziarnisty, liście laurowe, koperek. Po kwadransie dodać kalafiora i szczyptę curry (opcjonalnie). Gotować na małym ogniu pół godziny. W razie potrzeby doprawić."
    },
    "18": {
      "id": 18,
      "name": "Czekolada gorzka 85% kakao",
      "recipe": ""
    },
    "19": {
      "id": 19,
      "name": "Mozzarella zapiekana z papryką i awokado",
      "recipe": "Pokrój w plastry mozzarellę, awokado i pomidora. Ułóż na przemian na talerzu. Dodaj listki bazylii i przypraw solą i pieprzem. Posyp słonecznik, zapiecz w airfryerze z pieczywem (opcjonalnie)."
    },
    "20": {
      "id": 20,
      "name": "Grzanki z serkiem i szynką",
      "recipe": "Zapiecz bułkę, posmaruj masłem i serkiem, dodaj szynkę i warzywa."
    },
    "21": {
      "id": 21,
      "name": "Owsianka z malinami i czekoladą",
      "recipe": "Płatki owsiane wymieszać z siemieniem lnianym/chia. Zalać wrzątkiem, odstawić na 5-10 minut, dodać jogurt, maliny, kawałki czekolady. Posypać cynamonem."
    },
    "22": {
      "id": 22,
      "name": "Frytki warzywne w ziołach",
      "recipe": "Warzywa obierz i pokrój w paski. Następnie obsyp solą i ziołami (bazylia, oregano, tymianek). Zapiecz do miękkości w airfryerze."
    },
    "23": {
      "id": 23,
      "name": "Pierś z indyka caprese",
      "recipe": "Przygotuj marynatę do mięsa: wymieszaj 1 łyżkę oleju, zioła, pieprz, sól i sprasowany czosnek. Natrzyj marynatą fileta i odstaw na 20 minut. Przełóż do naczynia żaroodpornego, natnij wzdłuż i w miejscach nacięć włóż na przemian plastry pomidora i mozzarelli. Piecz ok. 20 minut w 180°C. Podawaj z warzywami."
    },
    "24": {
      "id": 24,
      "name": "Banan",
      "recipe": ""
    },
    "25": {
      "id": 25,
      "name": "Tortilla z awokado i szynką",
      "recipe": "Tortilla posmaruj miękkim awokado, dodaj plasterki szynki, pokrojoną paprykę i sałatę. Dopraw wg uznania."
    },
    "26": {
      "id": 26,
      "name": "Omlet z malinami i pistacjami",
      "recipe": "Jaja rozbij i ubij na płynną postać. Wlej masę na patelnię i smaż pod przykryciem aż do ścięcia jaj. Po usmażeniu polej jogurtem i posyp pistacjami i cynamonem. Na wierzchu połóż maliny."
    },
    "27": {
      "id": 27,
      "name": "Kanapka pełnoziarnista z awokado i fetą",
      "recipe": "Chleb razowy obłożyć plastrami awokado, wyłożyć pokruszony ser, pokrojoną paprykę i roszponkę. Można zapiec."
    },
    "28": {
      "id": 28,
      "name": "Zupa pomidorowa z makaronem ryżowym",
      "recipe": "Marchewkę, pietruszkę i pora umyj, obierz i pokrój. Podsmaż warzywa na oliwie. Wrzuć pokrojone świeże pomidory oraz pomidory z puszki. Gotuj aż pomidory się rozpadną. Zalej bulionem/wodą, dodaj liść laurowy i gotuj przez 15-20 minut. Dodaj ugotowane mięso z indyka pokrojone na kawałki. Dodaj ugotowany makaron ryżowy. Dodaj posiekaną natkę pietruszki, dopraw solą i pieprzem."
    },
    "29": {
      "id": 29,
      "name": "Jabłko",
      "recipe": ""
    },
    "30": {
      "id": 30,
      "name": "Zapiekana mozzarella z pomidorkami",
      "recipe": "Chleb, plastry sera z pomidorkami przeciętymi na pół zgrillować/zapiec w airfryerze. Podać z musztardą i grzanką. Doprawić, posypać natką."
    },
    "31": {
      "id": 31,
      "name": "Grzanki z serkiem śmietankowym, rzodkiewką i ogórkiem",
      "recipe": "Kromki chleba zapiec w piekarniku lub tosterze aby były chrupkie. Rozsmarować serek, dodać szynkę i warzywa plus szczypiorek."
    },
    "32": {
      "id": 32,
      "name": "Owsianka gruszkowa z cynamonem i orzechami",
      "recipe": "Płatki zalać wrzątkiem, odstawić do nasiąknięcia. Dodać pokrojone owoce i resztę składników, wymieszać."
    },
    "33": {
      "id": 33,
      "name": "Mizeria",
      "recipe": "Ogórki obrać i zetrzeć na tarce lub pokroić w cienkie plasterki. Przygotować sos z oliwy, soku z cytryny, jogurtu i przypraw. Wymieszać całość z posiekanym koperkiem."
    },
    "34": {
      "id": 34,
      "name": "Frytki z marchewki w ziołach",
      "recipe": "Pokrój marchewki w słupki. Skrop oliwą. Całość przypraw i wymieszaj. Nagrzej piekarnik do 200 st. Piecz 30 min."
    },
    "35": {
      "id": 35,
      "name": "Burger pietruszkowy",
      "recipe": "Mięso wymieszaj z posiekaną natką, czosnkiem, dopraw wg uznania. Uformuj burgera i upiecz do miękkości w airfryerze. Podaj z warzywami i mizerią."
    },
    "36": {
      "id": 36,
      "name": "Cynamonowy skyr z kiwi",
      "recipe": "Jogurt wymieszaj z kiwi i cynamonem."
    },
    "37": {
      "id": 37,
      "name": "Sałatka z pomidorkami i słonecznikiem",
      "recipe": "Pomidora/pomidorki pokrój w ósemki, cebulę w półksiężyce. Wymieszaj razem z oliwą, słonecznikiem i ulubionymi przyprawami. Podaj z serkiem, opcjonalnie dołóż pieczywo."
    },
    "38": {
      "id": 38,
      "name": "Serek wiejski lekki",
      "recipe": ""
    },
    "39": {
      "id": 39,
      "name": "Zielony omlet z fetą",
      "recipe": "Jaja rozbij i ubij na płynną postać. Do płynnej masy jajecznej dodaj posiekaną bazylię, kawałeczki papryki. Roztrzep na płynną postać. Wylej masę na rozgrzaną patelnię bez tłuszczu. Duś pod przykryciem do ścięcia się omleta na delikatnie złocisty kolor. Na końcu smażenia dodaj pokruszoną fetę. Podaj z pieczywem."
    },
    "40": {
      "id": 40,
      "name": "Jogurt grecki",
      "recipe": ""
    },
    "41": {
      "id": 41,
      "name": "Pistacje surowe",
      "recipe": ""
    },
    "42": {
      "id": 42,
      "name": "Schab pieczony z kaszą i duszoną cukinią SR",
      "recipe": "Schab natrzeć oliwą z czosnkiem i przyprawami: szczypta soli, pieprzu, tymianku, ziół prowansalskich, papryki czerwonej słodkiej. Schab piec w folii w piekarniku nagrzanym do 180°C przez 30 minut. Cukinię obrać i pokroić w półksiężyce, poddusić z pomidorem bez skórki i doprawić bazylią, solą i pieprzem. Mięso podawać z ugotowaną kaszą i duszonymi warzywami."
    },
    "43": {
      "id": 43,
      "name": "Twarożek bazyliowy z papryką",
      "recipe": "Twaróg wymieszaj z pokrojonymi papryką i ogórkiem. Dodaj posiekaną bazylię i sól. Zjedz z pieczywem."
    }
  },
